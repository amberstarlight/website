{%- set pageTitle %}
  {% if title %}
    {{ title }} | {{ meta.data.siteName }}
  {% else %}
    {{ meta.data.siteName }}
  {% endif %}
{% endset -%}

{%- set pageDescription %}
  {% if subtitle %}
    {{ subtitle }}
  {% else %}
    {{ meta.data.siteDescription }}
  {% endif %}
{% endset -%}

{%
  set commitURL = [
    meta.data.gitURL,
    "/commit/",
    gitSha
  ] | join
%}

{%- css %}
  {% include "../../src/assets/css/reset.css" %}
  {% include "../../src/assets/css/variables.css" %}
  {% include "../../src/assets/css/fonts.css" %}
  {% include "../../src/assets/css/main.css" %}
  {% include "../../src/assets/css/crumbs.css" %}
  {% include "../../src/assets/css/dateline.css" %}
  {% include "../../src/assets/css/lists.css" %}
  {% include "../../src/assets/css/main-wrapper.css" %}
  {% include "../../src/assets/css/minimal-button.css" %}
  {% include "../../src/assets/css/note.css" %}
  {% include "../../src/assets/css/pagination.css" %}
  {% include "../../src/assets/css/post.css" %}
  {% include "../../src/assets/css/post-info.css" %}
  {% include "../../src/assets/css/splash.css" %}
  {% include "../../src/assets/css/spoiler.css" %}
  {% include "../../src/assets/css/sticky.css" %}
  {% include "../../src/assets/css/title.css" %}
  {% include "../../src/assets/prism-tomorrow.min.css" %}
{% endcss %}

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <base href="/" />
    <title>{{ pageTitle | safe }}</title>
    <link rel="stylesheet" href="{% getBundleFileUrl "css" %}">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content="{{ eleventy.generator }}" />

    {# open graph #}
    <meta name="og:title" content="{{ pageTitle | trim }}" />
    <meta name="og:site_name" content="amber.vision">
    <meta name="og:description" content="{{ pageDescription | trim }}" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:date" content="{{ page.date.toISOString() }}" />

    {# open graph image #}
    {% set post = page.url.split("/blog/")[1] %}
    {% if post | length > 2 %}
    <meta property="og:image" content="/assets/img/og/{{ page.fileSlug }}.png"/>
    <meta name="twitter:card" content="summary_large_image">
    {% endif %}

    {# twitter #}
    <meta name="twitter:title" content="{{ pageTitle | trim }}" />
    <meta name="twitter:description" content="{{ pageDescription | trim }}" />

    <meta name="theme-color" content="#cc2851">
  </head>
  <body>
    <div class="main-wrapper">
      {{ content | parseFootnotes | parseSpoilers | safe }}
      <footer>
        <img src="/assets/img/me.webp" width="100" />
        <p>Me: <a href="https://amber.vision" rel="me">amber.vision</a></p>
        <div>
          <p>
            &copy; 2023 - {% year %}
            <br />
            Code available under <a href="https://www.gnu.org/licenses/gpl-3.0.en.html">GPL-3.0-or-later</a>
            <br />
            Article text available under <a href="https://creativecommons.org/licenses/by-sa/4.0/legalcode">CC-BY-SA-4.0</a>
            <br />
            Short SHA-1: <a href={{commitURL}}>{{ gitShortSha }}</a>
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
