{% set backUrl = "" %}
{% set backName = "" %}
<nav class="sticky">
  <ul class="crumbs">
    {% for crumb in breadcrumbs %}
      {% if loop.last %}
        <li>{{ crumb.name }}</li>
      {% else %}
        {% set backUrl = crumb.url %}
        {% set backName = crumb.name %}
        <li><a href="{{ crumb.url }}">{{ crumb.name }}</a></li>
      {% endif %}
    {% endfor %}
  </ul>
  <a href="{{ backUrl }}" class="back">back to {{ backName }}</a>
  <a href="{{ page.url }}#top" class="minimal-button">top &uarr;</a>
</nav>
